# Enable Rewrite Engine
RewriteEngine On
Options -MultiViews
RewriteBase /

# -----------------------------------
# 4XX Error Redirects - Fix broken URLs
# -----------------------------------
Redirect 301 /same-day-agra-tour-by-train https://touranzza.com/same-day-agra-tour-by-gatimaan-express
Redirect 301 /golden-triangle-tour-india https://touranzza.com/golden-triangle-tours
Redirect 301 /taj-mahal-tour-packages https://touranzza.com/tour-packages
Redirect 301 /agra-tours https://touranzza.com/same-day-tours

# -----------------------------------
# www to non-www redirect (SEO best practice)
# -----------------------------------
RewriteCond %{HTTP_HOST} ^www\.touranzza\.com [NC]
RewriteRule ^(.*)$ https://touranzza.com/$1 [L,R=301]

# -----------------------------------
# 1. Redirect index.php to root
# -----------------------------------
RewriteCond %{THE_REQUEST} \s.*/index\.php[\s?] [NC]
RewriteRule ^index\.php$ ./ [L,R=302]

# -----------------------------------
# 2. Remove .php extension from external requests
# -----------------------------------
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?] [NC]
RewriteRule ^([^.]+)\.php$ $1 [L,R=302]

# -----------------------------------
# 3. Internal rewrite to .php
# -----------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]